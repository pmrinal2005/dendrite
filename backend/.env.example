# ============================================================
# DENDRITE Backend — Environment Variables
# ============================================================
# These are deployment-level defaults. Per-request BYOK headers
# from the frontend always override them.
# ============================================================

# CORS — comma-separated origins. Use "*" for development only.
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# MIRL model deployment names (must match what you actually deploy in Foundry)
MIRL_TIER1_MODEL=Phi-4-mini-instruct
MIRL_TIER2_MODEL=gpt-4o-mini
MIRL_TIER3_MODEL=gpt-4.1-mini
MIRL_TIER4_MODEL=o4-mini

# Confidence gate below which the Critic agent is invoked (0.0 - 1.0)
CONFIDENCE_GATE=0.72

# Where to write JSONL audit/trace logs. Render: use a persistent disk
# mount like /var/data/logs. Vercel/serverless: leave unset (auto /tmp).
# DENDRITE_LOG_DIR=/var/data/logs

# Optional fallback Foundry creds if you ever want to run WITHOUT BYOK.
# Leave blank in production — frontend BYOK headers always win.
# AZURE_FOUNDRY_ENDPOINT=
# AZURE_FOUNDRY_KEY=
